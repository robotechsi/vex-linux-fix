{
  "manifest_version": 3,
  "name": "VEX Touch Fix",
  "version": "1.2",
  "content_scripts": [{
    "matches": [
      "*://codeiq.vex.com/*",
      "*://codeair.vex.com/*",
      "*://code123.vex.com/*",
      "*://codego.vex.com/*",
      "*://codeaim.vex.com/*",
      "*://codeexp.vex.com/*",
      "*://codev5.vex.com/*"
    ],
    "js": ["fix.js"],
    "run_at": "document_start",
    "world": "MAIN"
  }]
}
